[Desktop Entry]
Type=Application
Version=1.0
Name=${DISPLAY}
GenericName=AI Coding IDE
Comment=${DISPLAY} (unofficial Linux package)
Exec=/usr/bin/${PKG_NAME} %U
Icon=${PKG_NAME}
StartupNotify=true
StartupWMClass=${WMCLASS}
Categories=Development;IDE;Utility;
Terminal=false
MimeType=x-scheme-handler/${TRAE_SCHEME};

